DELIMITER $$
CREATE PROCEDURE sp_finalizar_pagamento(
    IN p_id_atendimento INT,
    IN p_forma VARCHAR(20)
)
BEGIN

    DECLARE v_valor DECIMAL(10,2);
    DECLARE v_id_pagamento INT;
    DECLARE v_status VARCHAR(20);

   
    IF p_forma NOT IN ('Pix', 'Cartao', 'Dinheiro') THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Forma de pagamento inválida';
    END IF;

    SELECT id_pagamento, valor, status_pagamento
    INTO v_id_pagamento, v_valor, v_status
    FROM Pagamento
    WHERE id_atendimento = p_id_atendimento;

    IF v_id_pagamento IS NULL THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Pagamento não encontrado';
    END IF;

    IF v_status = 'Pago' THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Pagamento já realizado';
    END IF;

    IF v_status = 'Cancelado' THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Não é possível realizar pagamento de um atendimento cancelado';
    END IF;
    
    SET v_valor = fn_calcular_pagamento(v_valor, p_forma);

   
    UPDATE Pagamento
    SET forma_pagamento = p_forma,
        valor = v_valor,
        status_pagamento = 'Pago'
    WHERE id_pagamento = v_id_pagamento;

END $$

DELIMITER ;


DELIMITER $$

CREATE TRIGGER trg_criar_pagamento
AFTER UPDATE ON Atendimento
FOR EACH ROW
BEGIN

    DECLARE v_valor DECIMAL(10,2);

   
    IF NEW.status_atendimento = 'Realizado'
       AND OLD.status_atendimento <> 'Realizado' THEN

    
        SELECT s.preco
        INTO v_valor
        FROM Servico s
        WHERE s.id_servico = NEW.id_servico;

    
        INSERT INTO Pagamento(
            valor,
            forma_pagamento,
            status_pagamento,
            id_atendimento
        )
        VALUES(
            v_valor,
             'Dinheiro',
            'Pendente',
            NEW.id_atendimento
        );

    END IF;

END $$

DELIMITER ;
